/// Maps raw platform/backend exceptions to [AppException] subtypes.
///
/// Call this in repository implementations to translate technical errors
/// into user-friendly errors before they reach the UI.
abstract final class ErrorHandler {
  /// Wraps [action] in a try/catch that maps raw exceptions to [AppException].
  static Future<T> guard<T>(Future<T> Function() action) async {
    try {
      return await action();
    } on AppException {
      rethrow;
{{#SUPABASE}}
    } on supabase.AuthException catch (e, st) {
      AppLogger.e('[ErrorHandler] Auth error', error: e, stackTrace: st);
      throw const AuthException();
    } on supabase.PostgrestException catch (e, st) {
      AppLogger.e('[ErrorHandler] Database error', error: e, stackTrace: st);
      throw const StorageException();
{{/SUPABASE}}
{{#FIREBASE}}
    } on fb_auth.FirebaseAuthException catch (e, st) {
      AppLogger.e('[ErrorHandler] Firebase Auth error', error: e, stackTrace: st);
      throw const AuthException();
    } on FirebaseException catch (e, st) {
      AppLogger.e('[ErrorHandler] Firebase error', error: e, stackTrace: st);
      throw const StorageException();
{{/FIREBASE}}
    } on FormatException catch (e, st) {
      AppLogger.e('[ErrorHandler] Validation error', error: e, stackTrace: st);
      throw const ValidationException();
    } catch (e, st) {
      // Catches SocketException, HttpException, and any other unexpected errors.
      // SocketException requires dart:io which is unavailable on web — catching
      // broadly here keeps the template web-compatible.
      final isNetwork = e.runtimeType.toString().contains('SocketException') ||
          e.runtimeType.toString().contains('HttpException');
      if (isNetwork) {
        AppLogger.e('[ErrorHandler] Network error', error: e, stackTrace: st);
        throw const NetworkException();
      }
      AppLogger.e('[ErrorHandler] Unexpected error', error: e, stackTrace: st);
      throw const UnexpectedException();
    }
  }
}
