import 'package:flutter/foundation.dart';

import 'package:{{PACKAGE_NAME}}/core/utils/app_logger.dart';

/// In-memory queue of pending sync operations for offline-first patterns.
///
/// **Important:** This is an in-memory stub. For production, persist the queue
/// to local storage (Isar, Drift, or SQLite) so pending mutations survive
/// app restarts. Implement [loadFromStorage] and [saveToStorage] in a subclass.
@immutable
class SyncQueue {
  const SyncQueue({this.operations = const []});

  final List<SyncOperation> operations;

  /// Add an operation to the queue. Returns a new [SyncQueue].
  SyncQueue enqueue(SyncOperation operation) =>
      SyncQueue(operations: [...operations, operation]);

  /// Process all pending operations. Returns a new [SyncQueue] with only failures.
  Future<SyncQueue> processAll(
    Future<void> Function(SyncOperation) executor,
  ) async {
    final failures = <SyncOperation>[];

    for (final op in operations) {
      try {
        await executor(op);
      } catch (e, st) {
        AppLogger.e(
          '[SyncQueue] Failed to sync ${op.entityType}/${op.entityId}',
          error: e,
          stackTrace: st,
        );
        failures.add(op);
      }
    }

    return SyncQueue(operations: failures);
  }

  /// Number of pending operations.
  int get pendingCount => operations.length;

  /// Whether the queue is empty.
  bool get isEmpty => operations.isEmpty;
}

/// A single sync operation.
@immutable
class SyncOperation {
  const SyncOperation({
    required this.type,
    required this.entityType,
    required this.entityId,
    required this.payload,
    required this.createdAt,
  });

  final SyncOperationType type;
  final String entityType;
  final String entityId;
  final Map<String, dynamic> payload;
  final DateTime createdAt;
}

enum SyncOperationType { create, update, delete }
